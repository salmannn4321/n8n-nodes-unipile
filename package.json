{
	"name": "n8n-nodes-unipile-api",
	"version": "1.0.6",
	"description": "n8n community node for Unipile — automate LinkedIn outreach, connection requests, InMail and messaging via Unipile API",
	"license": "MIT",
	"homepage": "https://github.com/salmannn4321/n8n-nodes-unipile",
	"keywords": [
		"n8n-community-node-package",
		"unipile",
		"linkedin",
		"outreach",
		"automation",
		"inmail",
		"messaging",
		"connection-request"
	],
	"author": {
		"name": "Salman Mehboob",
		"email": "salmanmehboob1947@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/salmannn4321/n8n-nodes-unipile.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/UnipileApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Unipile/Unipile.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}